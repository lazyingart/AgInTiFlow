{
  "name": "@lazyingart/agintiflow",
  "version": "0.20.80",
  "type": "module",
  "description": "Low-cost, project-aware Web and CLI agents with DeepSeek/Venice/OpenAI routing, visible tool calls, durable sessions, scouts, AAPS, SCS, and guarded local execution.",
  "license": "Apache-2.0",
  "homepage": "https://flow.lazying.art",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lazyingart/AgInTiFlow.git"
  },
  "bugs": {
    "url": "https://github.com/lazyingart/AgInTiFlow/issues"
  },
  "keywords": [
    "agent",
    "automation",
    "browser",
    "playwright",
    "deepseek",
    "venice",
    "openai",
    "qwen",
    "sandbox",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "AGENTS.md",
    "LICENSE",
    "README.md",
    "bin/",
    "docs/",
    "docker/",
    "demos/agintiflow-cli-launch.jpg",
    "demos/agintiflow-web-console-run-output.jpg",
    "i18n/",
    "logos/banner-opaque.png",
    "logos/logo.png",
    "public/",
    "website/assets/screenshots/*.jpg",
    "references/*.md",
    "references/notes/*.md",
    "references/run_design_scan.sh",
    "scripts/install-docker-ubuntu.sh",
    "scripts/setup-agent-toolchain-docker.sh",
    "scripts/real-deepseek-capabilities.js",
    "scripts/smoke-auxiliary-tools.js",
    "scripts/smoke-auth.js",
    "scripts/smoke-aaps-adapter.js",
    "scripts/smoke-canvas-artifacts.js",
    "scripts/smoke-cli-chat.js",
    "scripts/smoke-coding-tools.js",
    "scripts/smoke-capabilities.js",
    "scripts/smoke-auto-update.js",
    "scripts/smoke-inbox.js",
    "scripts/smoke-model-roles.js",
    "scripts/smoke-platform.js",
    "scripts/smoke-skills.js",
    "scripts/smoke-skillmesh.js",
    "scripts/smoke-tmux-tools.js",
    "scripts/smoke-toolchain-docker.js",
    "scripts/smoke-web-api.js",
    "src/",
    "run.js",
    "skills/",
    "web.js"
  ],
  "bin": {
    "aginti": "bin/aginti-cli.js",
    "aginti-cli": "bin/aginti-cli.js"
  },
  "scripts": {
    "start": "node run.js",
    "web": "node web.js",
    "check": "node --check run.js && node --check web.js && node --check bin/aginti-cli.js && node --check src/*.js && node --check scripts/seed-supervised-homework.js",
    "setup:toolchain-docker": "scripts/setup-agent-toolchain-docker.sh",
    "smoke:coding-tools": "node scripts/smoke-coding-tools.js",
    "smoke:aaps-adapter": "node scripts/smoke-aaps-adapter.js",
    "smoke:auxiliary-tools": "node scripts/smoke-auxiliary-tools.js",
    "smoke:auth": "node scripts/smoke-auth.js",
    "smoke:canvas-artifacts": "node scripts/smoke-canvas-artifacts.js",
    "smoke:cli-chat": "node scripts/smoke-cli-chat.js",
    "smoke:skills": "node scripts/smoke-skills.js",
    "smoke:skillmesh": "node scripts/smoke-skillmesh.js",
    "smoke:toolchain-docker": "node scripts/smoke-toolchain-docker.js",
    "smoke:inbox": "node scripts/smoke-inbox.js",
    "smoke:model-roles": "node scripts/smoke-model-roles.js",
    "smoke:platform": "node scripts/smoke-platform.js",
    "smoke:tmux-tools": "node scripts/smoke-tmux-tools.js",
    "smoke:web-api": "node scripts/smoke-web-api.js",
    "smoke:autoupdate": "node scripts/smoke-auto-update.js",
    "real:deepseek": "node scripts/real-deepseek-capabilities.js",
    "supervision:seed": "node scripts/seed-supervised-homework.js",
    "storage:migrate": "node bin/aginti-cli.js storage migrate",
    "test": "npm run check && npm run smoke:autoupdate && npm run smoke:web-api && npm run smoke:coding-tools && npm run smoke:aaps-adapter && npm run smoke:auxiliary-tools && npm run smoke:auth && npm run smoke:canvas-artifacts && npm run smoke:capabilities && npm run smoke:model-roles && npm run smoke:platform && npm run smoke:skills && npm run smoke:skillmesh && npm run smoke:tmux-tools && npm run smoke:cli-chat && npm run smoke:inbox",
    "pack:dry-run": "npm pack --dry-run",
    "smoke:capabilities": "node scripts/smoke-capabilities.js"
  },
  "dependencies": {
    "express": "^5.1.0",
    "openai": "^6.3.0",
    "playwright": "^1.55.0"
  }
}
